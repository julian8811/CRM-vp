{
  "rewrites": [
    {
      "source": "/crm-vp-app/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/crm-vp-app/favicon.svg",
      "destination": "/favicon.svg"
    },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "env": {
    "VITE_SUPABASE_URL": "@supabase-url",
    "VITE_SUPABASE_ANON_KEY": "@supabase-anon-key"
  }
}
